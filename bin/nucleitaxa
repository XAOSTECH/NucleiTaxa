#!/bin/bash

# NucleiTaxa CLI - Main Orchestrator
# Supports CPU and optional CUDA GPU acceleration
# Usage: ./bin/nucleitaxa --forward R1.fastq.gz --reverse R2.fastq.gz [--cuda] --output results

set -e

# Color codes for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Default values
FORWARD=""
REVERSE=""
OUTPUT="results"
PROFILE="16s"
JOBS=$(nproc)
USE_CUDA=false
DRY_RUN=false
RESUME_FROM=0
ANALYTICS_LIVE=false
CHIMERA_THRESHOLD=0.85

# Parse arguments
while [[ $# -gt 0 ]]; do
    case $1 in
        --forward)
            FORWARD="$2"
            shift 2
            ;;
        --reverse)
            REVERSE="$2"
            shift 2
            ;;
        --output)
            OUTPUT="$2"
            shift 2
            ;;
        --profile)
            PROFILE="$2"
            shift 2
            ;;
        --jobs)
            JOBS="$2"
            shift 2
            ;;
        --cuda)
            USE_CUDA=true
            shift
            ;;
        --no-cuda)
            USE_CUDA=false
            shift
            ;;
        --cuda-stages)
            CUDA_STAGES="$2"
            shift 2
            ;;
        --dry-run)
            DRY_RUN=true
            shift
            ;;
        --resume-from)
            RESUME_FROM="$2"
            shift 2
            ;;
        --analytics-live)
            ANALYTICS_LIVE=true
            shift
            ;;
        --chimera-threshold)
            CHIMERA_THRESHOLD="$2"
            shift 2
            ;;
        *)
            echo "Unknown option: $1"
            exit 1
            ;;
    esac
done

# Validate inputs
if [ -z "$FORWARD" ] || [ -z "$REVERSE" ]; then
    echo -e "${RED}Error: --forward and --reverse are required${NC}"
    echo "Usage: ./bin/nucleitaxa --forward R1.fastq.gz --reverse R2.fastq.gz --output results [--cuda]"
    exit 1
fi

# Check GPU availability if CUDA requested
if [ "$USE_CUDA" = true ]; then
    if command -v nvidia-smi &> /dev/null; then
        echo -e "${BLUE}[INFO]${NC} GPU detected. Enabling CUDA acceleration..."
        nvidia-smi --query-gpu=name,memory.total --format=csv,noheader
    else
        echo -e "${YELLOW}[WARN]${NC} --cuda flag set but nvidia-smi not found. Falling back to CPU..."
        USE_CUDA=false
    fi
fi

# Create output directory
mkdir -p "$OUTPUT"

# Log header
echo -e "${BLUE}╔════════════════════════════════════════════════════════════╗${NC}"
echo -e "${BLUE}║${NC}          NucleiTaxa Amplicon Analysis Pipeline             ${BLUE}║${NC}"
echo -e "${BLUE}╚════════════════════════════════════════════════════════════╝${NC}"
echo ""
echo -e "Profile:    ${YELLOW}$PROFILE${NC}"
echo -e "Input:      ${YELLOW}$FORWARD / $REVERSE${NC}"
echo -e "Output:     ${YELLOW}$OUTPUT${NC}"
echo -e "Jobs:       ${YELLOW}$JOBS${NC}"
echo -e "GPU:        ${YELLOW}$([ "$USE_CUDA" = true ] && echo "ENABLED" || echo "DISABLED")${NC}"
echo -e "Analytics:  ${YELLOW}$([ "$ANALYTICS_LIVE" = true ] && echo "LIVE" || echo "DISABLED")${NC}"
echo ""

if [ "$DRY_RUN" = true ]; then
    echo -e "${YELLOW}[DRY RUN MODE]${NC} - No files will be modified"
    echo ""
fi

# Define pipeline stages
declare -a STAGES=(
    "01-preprocess"
    "02-denoise-dada2"
    "03-chimera-vsearch"
    "04-taxonomy-rdp"
    "05-phylo-fasttree"
    "06-krona-viz"
)

# Execute pipeline stages
for i in "${!STAGES[@]}"; do
    STAGE_NUM=$((i + 1))
    
    # Skip stages before resume point
    if [ "$STAGE_NUM" -lt "$RESUME_FROM" ]; then
        echo -e "${YELLOW}[SKIP]${NC} Stage $STAGE_NUM: ${STAGES[$i]} (resuming from stage $RESUME_FROM)"
        continue
    fi
    
    STAGE_SCRIPT="pipeline/${STAGES[$i]}.sh"
    
    if [ ! -f "$STAGE_SCRIPT" ]; then
        echo -e "${RED}[ERROR]${NC} Pipeline script not found: $STAGE_SCRIPT"
        exit 1
    fi
    
    echo -e "${BLUE}[STAGE $STAGE_NUM]${NC} Running ${STAGES[$i]}..."
    
    # Prepare stage arguments
    STAGE_ARGS="--output $OUTPUT --profile $PROFILE --jobs $JOBS --chimera-threshold $CHIMERA_THRESHOLD"
    
    # Add GPU flag for specific stages if enabled
    if [ "$USE_CUDA" = true ]; then
        if [[ "$STAGE_NUM" == "03" || "$STAGE_NUM" == "05" ]]; then
            STAGE_ARGS="$STAGE_ARGS --cuda"
            echo -e "${GREEN}[CUDA]${NC} Enabling GPU acceleration for this stage"
        fi
    fi
    
    if [ "$DRY_RUN" = false ]; then
        # Execute stage
        bash "$STAGE_SCRIPT" \
            --forward "$FORWARD" \
            --reverse "$REVERSE" \
            $STAGE_ARGS
        
        if [ $? -eq 0 ]; then
            echo -e "${GREEN}[PASS]${NC} Stage $STAGE_NUM: ${STAGES[$i]}"
        else
            echo -e "${RED}[FAIL]${NC} Stage $STAGE_NUM: ${STAGES[$i]}"
            echo "To resume from this point, use: --resume-from $((STAGE_NUM + 1))"
            exit 1
        fi
    else
        echo -e "${YELLOW}[DRY]${NC} Would execute: bash $STAGE_SCRIPT $STAGE_ARGS"
    fi
    
    echo ""
done

echo -e "${BLUE}╔════════════════════════════════════════════════════════════╗${NC}"
echo -e "${GREEN}✓${NC} Pipeline completed successfully!"
echo -e "${BLUE}╚════════════════════════════════════════════════════════════╝${NC}"
echo ""
echo -e "Results location: ${YELLOW}$OUTPUT/${NC}"
echo -e "View visualization: ${YELLOW}open $OUTPUT/06-viz/taxa_krona.html${NC}"
